{
  "expo": {
    "name": "absensiApp",
    "slug": "absensiApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "absensiapp",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/logo-splash-screen.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F62FE"
    },
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "splash": {
        "image": "./assets/images/logo-splash-screen.png",
        "resizeMode": "contain",
        "backgroundColor": "#0F62FE"
      }
    },
    "android": {
      "splash": {
        "image": "./assets/images/logo-splash-screen.png",
        "resizeMode": "contain",
        "backgroundColor": "#0F62FE"
      },
      "adaptiveIcon": {
        "backgroundColor": "#0F62FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/logo-splash-screen.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.absensiApp",
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.CALL_PHONE",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_MEDIA_AUDIO"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logo-splash-screen.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#0F62FE",
          "dark": {
            "backgroundColor": "#001D6C"
          }
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Izinkan absensiApp mengakses foto untuk menampilkan bukti selfie.",
          "savePhotosPermission": "Izinkan absensiApp menyimpan foto selfie ke galeri perangkat.",
          "isAccessMediaLocationEnabled": false
        }
      ]
    ],
    "experiments": {
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0e2cdf4c-4653-4646-b6d1-e480debc2160"
      }
    }
  }
}
